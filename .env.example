# Supabase PostgreSQL
# Lấy từ Supabase Dashboard → Project Settings → Database
ConnectionStrings__DefaultConnection=Host=db.xxxx.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# JWT
Jwt__Key=SoChungSecretKey_ChangeThisInProduction_MinLength32Chars
Jwt__Issuer=SoChungAPI
Jwt__Audience=SoChungApp
Jwt__TokenExpiryDays=7

# Email SMTP
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__Username=your-email@gmail.com
Email__Password=your-16-char-app-password
Email__FromName=SoChung App

# App
App__FrontendUrl=https://your-frontend-url.com
